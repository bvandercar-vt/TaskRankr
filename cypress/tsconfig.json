{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "types": ["node", "cypress"],
    "esModuleInterop": true,
    "moduleResolution": "node",
    "strict": true,
    "paths": {
      "@cypress/support/*": ["./support/*"],
      "@src/*": ["../shared/*"],
      "@src/client/*": ["../client/src/*"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["../node_modules"]
}
