{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "types": ["cypress"],
    "esModuleInterop": true,
    "moduleResolution": "node",
    "strict": true,
    "paths": {
      "@cypress/support/*": ["./support/*"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["../node_modules"]
}
